---
type Project = {
  title: string;
  href: string;
  language: string;
  createdDate: string;
  summary: string;
  framing: string;
  whatItShows: string;
  metrics: string;
  originality: string;
  featuredOnLinkedIn: boolean;
};

const { project } = Astro.props as { project: Project };
const evidenceLine = project.metrics || project.framing || project.whatItShows;
const metaLine = [project.createdDate, project.language].filter(Boolean).join(" · ");
---

<article class="project-card">
  <div class="publication-meta-row">
    <span class="pill">{project.originality}</span>
    {metaLine && <span class="meta-kicker">{metaLine}</span>}
  </div>
  <h3>{project.title}</h3>
  <p class="card-body">{project.summary}</p>
  {evidenceLine && <p class="project-metrics">{evidenceLine}</p>}
  <div class="card-links">
    <a href={project.href} target="_blank" rel="noreferrer">Open repository</a>
  </div>
</article>
