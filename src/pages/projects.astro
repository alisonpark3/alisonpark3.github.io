---
import MainLayout from "../layouts/MainLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects, siteMeta } from "../data/site";
---

<MainLayout title={`${siteMeta.title} | Projects`} description="Public code repositories and notebooks for Alison Seongjee Park.">
  <section class="subpage-hero">
    <div class="content-grid narrow-grid">
      <p class="hero-kicker">Public code</p>
      <h1>Projects</h1>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <div class="card-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>

      <div class="contact-strip">
        <a href={siteMeta.links.github} target="_blank" rel="noreferrer">View GitHub profile</a>
        <a href="/resume">Open resume page</a>
        <a href={`mailto:${siteMeta.email}`}>Email Alison</a>
      </div>
    </div>
  </section>
</MainLayout>
