---
import MainLayout from "../layouts/MainLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { projects, siteMeta } from "../data/site";
---

<MainLayout title={`${siteMeta.title} | Projects`} description="Selected public machine-learning projects for Alison Seongjee Park.">
  <section class="subpage-hero">
    <div class="content-grid narrow-grid">
      <p class="hero-kicker">Public code</p>
      <h1>Selected ML projects</h1>
      <p class="hero-body">
        These selected public projects complement Alison&apos;s research record by showing applied machine-learning and health-data analysis work in code, without
        claiming they are the center of the profile.
      </p>
      <div class="subpage-meta">
        <span class="pill">Healthcare classification</span>
        <span class="pill">Computer vision</span>
        <span class="pill">Public GitHub repos</span>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="What these repos add"
        title="Public code alongside the research record"
        body="The publications page shows scientific output. This page adds visible code artifacts that help recruiters and collaborators understand the applied machine-learning layer of the profile."
      />

      <div class="split-grid">
        <article class="split-card">
          <h3>Why keep them here</h3>
          <p>
            Recruiters and hiring managers often want to see public code alongside research output. These repositories provide that layer while keeping the
            publication record at the center of the portfolio.
          </p>
        </article>
        <article class="split-card">
          <h3>What they signal</h3>
          <p>
            They show healthcare framing, model-evaluation habits, and willingness to work in public across different machine-learning problem types.
          </p>
        </article>
      </div>

      <div class="card-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>

      <div class="contact-strip">
        <a href={siteMeta.links.github} target="_blank" rel="noreferrer">View GitHub profile</a>
        <a href="/resume">Open resume page</a>
        <a href={`mailto:${siteMeta.email}`}>Email Alison</a>
      </div>
    </div>
  </section>
</MainLayout>
