---
import { resumePageData, siteMeta } from "../data/site";

const resumeHeadline = "Machine learning | Bioinformatics | Multiple myeloma | Single-cell genomics";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteMeta.title} | Resume PDF</title>
    <style>
      :root {
        --ink: #18232d;
        --ink-soft: #41505d;
        --line: rgba(24, 35, 45, 0.15);
        --accent: #68819a;
      }

      @page {
        size: Letter;
        margin: 0.45in;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--ink);
        font-family: "Helvetica Neue", Arial, sans-serif;
        font-size: 9.5pt;
        line-height: 1.24;
      }

      h1, h2, h3, p, ul {
        margin: 0;
      }

      .resume-sheet {
        display: grid;
        gap: 10px;
      }

      .header {
        display: grid;
        gap: 4px;
        padding-bottom: 9px;
        border-bottom: 1px solid var(--line);
      }

      .header-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 12px;
      }

      .name {
        font-size: 22pt;
        font-weight: 800;
        letter-spacing: -0.04em;
      }

      .headline {
        font-size: 11pt;
        font-weight: 700;
        color: var(--accent);
      }

      .contact-line,
      .meta-line {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .contact-line a,
      .meta-line a {
        color: inherit;
        text-decoration: none;
      }

      .summary {
        font-size: 9.8pt;
        color: var(--ink-soft);
      }

      .two-column {
        display: grid;
        grid-template-columns: 1.55fr 0.95fr;
        gap: 18px;
      }

      .section {
        display: grid;
        gap: 6px;
      }

      .section-title {
        padding-bottom: 3px;
        border-bottom: 1px solid var(--line);
        font-size: 9.1pt;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .entry {
        display: grid;
        gap: 2px;
      }

      .entry-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
      }

      .entry-title {
        font-weight: 800;
      }

      .entry-subtitle {
        font-weight: 700;
      }

      .entry-date {
        font-weight: 700;
        white-space: nowrap;
      }

      .entry-note {
        color: var(--ink-soft);
      }

      ul {
        padding-left: 16px;
      }

      li + li {
        margin-top: 2px;
      }

      .skill-block strong,
      .compact-line strong {
        font-weight: 800;
      }

      .skill-block,
      .compact-line {
        color: var(--ink-soft);
      }

      .compact-line + .compact-line,
      .skill-block + .skill-block {
        margin-top: 5px;
      }

      @media screen and (max-width: 700px) {
        body {
          font-size: 10pt;
        }

        .resume-sheet {
          padding: 16px;
        }

        .header-top,
        .entry-head {
          display: grid;
          gap: 4px;
        }

        .name {
          font-size: 20pt;
          letter-spacing: -0.02em;
        }

        .headline {
          font-size: 10pt;
        }

        .two-column {
          grid-template-columns: 1fr;
          gap: 12px;
        }

        .entry-date {
          white-space: normal;
        }
      }
    </style>
  </head>
  <body>
    <main class="resume-sheet">
      <section class="header">
        <div class="header-top">
          <h1 class="name">{siteMeta.title}</h1>
          <p class="headline">{resumeHeadline}</p>
        </div>
        <div class="contact-line">
          <span>{siteMeta.location}</span>
          <span>{siteMeta.phone}</span>
          <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
          <a href={siteMeta.links.linkedin}>linkedin.com/in/alison-s-park</a>
        </div>
        <p class="summary">{resumePageData.summary}</p>
      </section>

      <section class="two-column">
        <div class="section">
          <h2 class="section-title">Selected Experience</h2>

          {resumePageData.experience.map((item) => (
            <article class="entry">
              <div class="entry-head">
                <div>
                  <p class="entry-title">{item.title}</p>
                  <p class="entry-subtitle">{item.organization}</p>
                </div>
                <p class="entry-date">{item.dates}</p>
              </div>
              <p class="entry-note">{item.scope}</p>
              <ul>
                {item.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>

        <div class="section">
          <h2 class="section-title">Education</h2>
          {resumePageData.education.map((item) => (
            <p class="compact-line">
              <strong>{item.title}</strong><br />
              {item.credential} | {item.dates}
            </p>
          ))}

          <h2 class="section-title">Technical Skills</h2>
          {resumePageData.skills.map((group) => (
            <p class="skill-block">
              <strong>{group.title}:</strong> {group.items.join(", ")}
            </p>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
