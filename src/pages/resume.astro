---
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { resumePageData, siteMeta } from "../data/site";
---

<MainLayout title={`${siteMeta.title} | Resume`} description="Recruiter-friendly resume page for Alison Seongjee Park.">
  <section class="subpage-hero">
    <div class="content-grid resume-hero-grid">
      <div class="resume-hero-copy">
        <p class="hero-kicker">For recruiters</p>
        <h1>Resume</h1>
        <p class="hero-body resume-summary">{resumePageData.summary}</p>
        <div class="subpage-meta">
          {resumePageData.highlightPills.map((item) => <span class="pill">{item}</span>)}
        </div>
        <div class="hero-actions">
          <a class="button button-primary" href={resumePageData.downloads.resumePdf} download>Download Resume (PDF)</a>
          <a class="button button-secondary" href={resumePageData.downloads.cvPdf} download>Full CV (PDF)</a>
          <a class="button button-tertiary" href={`mailto:${siteMeta.email}`}>Email Alison</a>
        </div>
      </div>

      <div class="resume-rail">
        <aside class="resume-panel">
          <p class="meta-kicker">Direct contact</p>
          <ul class="resume-contact-list">
            <li><span>Location</span><strong>{siteMeta.location}</strong></li>
            <li><span>Email</span><a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a></li>
            <li><span>Phone</span><a href={`tel:${siteMeta.phone.replace(/[^0-9+]/g, "")}`}>{siteMeta.phone}</a></li>
            <li><span>LinkedIn</span><a href={siteMeta.links.linkedin} target="_blank" rel="noreferrer">alison-s-park</a></li>
          </ul>
        </aside>

        <aside class="resume-panel">
          <p class="meta-kicker">Highlights</p>
          <div class="resume-download-stack">
            {resumePageData.railHighlights.map((item) => (
              <div class="resume-download-link">
                <strong>{item.title}</strong>
                <span>{item.body}</span>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="Education"
        title="Education"
        body="Training across biomedical science, medical school coursework, and applied data science."
      />

      <div class="resume-card-grid resume-card-grid-3">
        {resumePageData.education.map((item) => (
          <article class="resume-card">
            <p class="meta-kicker">{item.dates}</p>
            <h3>{item.title}</h3>
            <p class="resume-card-emphasis">{item.credential}</p>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell accent-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="Selected experience"
        title="Selected experience"
        body="Roles most relevant to computational biology, translational oncology, and applied machine-learning hiring."
      />

      <div class="resume-experience-stack">
        {resumePageData.experience.map((item) => (
          <article class="resume-card resume-experience-card">
            <div class="resume-experience-head">
              <div>
                <p class="meta-kicker">{item.dates}</p>
                <h3>{item.title}</h3>
                <p class="resume-card-emphasis">{item.organization}</p>
              </div>
              <p class="resume-experience-team">{item.scope}</p>
            </div>
            <ul class="calm-list">
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="Technical strengths"
        title="Technical skills"
        body="Methods and tools most evident in the current research stack."
      />

      <div class="resume-card-grid resume-strength-grid">
        {resumePageData.skills.map((group) => (
          <article class="resume-card">
            <h3>{group.title}</h3>
            <ul class="calm-list">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <div class="resume-cta">
        <div>
          <p class="section-eyebrow">Research archive</p>
          <h2>Need the publication record too?</h2>
          <p class="section-body">
            The publications page carries the formal paper and abstract record, including authorship order, poster PDFs, and source links.
          </p>
        </div>
        <div class="hero-actions">
          <a class="button button-primary" href="/publications">Publication archive</a>
          <a class="button button-secondary" href={`mailto:${siteMeta.email}`}>Email Alison</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
