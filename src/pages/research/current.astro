---
import MainLayout from "../../layouts/MainLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import FigureLightboxGrid from "../../components/FigureLightboxGrid.astro";
import { imsCurrentResearchPage, privateStagingMeta } from "../../data/private-staging";
---

<MainLayout
  title="Current Research | Daratumumab-aware MRD reanalysis"
  description="Private local staging page for the current multiple myeloma research program."
>
  <section class="subpage-hero">
    <div class="content-grid narrow-grid">
      <p class="hero-kicker">{imsCurrentResearchPage.hero.kicker}</p>
      <h1>{imsCurrentResearchPage.hero.title}</h1>
      <p class="hero-body">{imsCurrentResearchPage.hero.summary}</p>
      <div class="subpage-meta">
        {imsCurrentResearchPage.statusPills.map((item) => <span class="pill">{item}</span>)}
      </div>
      <div class="private-stage-banner">
        <strong>{privateStagingMeta.badge}</strong>
        <span>{privateStagingMeta.note}</span>
      </div>
    </div>
  </section>

  <section class="proof-section">
    <div class="content-grid">
      <div class="section-heading proof-heading">
        <p class="section-eyebrow">Study overview</p>
        <h2>Clinical question, cohort, and analytical scope</h2>
        <p class="section-body">
          This analysis reconstructs the MRD-conversion story around a treatment confound, then tests which
          signals remain after Dara-aware reruns, external validation, and orthogonal robustness checks
          across the immune and transcriptomic layers.
        </p>
      </div>

      <div class="proof-grid proof-grid-context">
        {
          imsCurrentResearchPage.proofStrip.map((item) => (
            <article class="proof-card">
              <p class="proof-label">{item.label}</p>
              <p class="proof-value">{item.value}</p>
              <p class="proof-note">{item.note}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="Background and rationale"
        title="From a treatment confound to a Dara-aware reanalysis"
        body="The analysis begins with a simple question: which MRD-conversion signals reflect disease biology, and which ones collapse once daratumumab exposure is modeled directly?"
      />

      <div class="split-grid">
        {imsCurrentResearchPage.narrativeBlocks.map((item) => (
          <article class="split-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell accent-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="Analytical framework"
        title="Dara-aware discovery, validation, and robustness analyses"
        body="The work moves from cohort reconstruction and covariate-aware reruns into communication, state-modeling, replication, and quality-control layers designed to keep the final claims defensible."
      />

      <div class="research-program-grid">
        {imsCurrentResearchPage.programGroups.map((item) => (
          <article class="story-card program-card">
            <div class="program-card-head">
              <p class="meta-kicker">{item.count}</p>
              <h3>{item.title}</h3>
            </div>
            <p>{item.body}</p>
            <div class="tag-row">
              {item.methods.map((method) => <span class="tag">{method}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="Representative results"
        title="Key figures from the current analysis set"
        body="These figures carry the strongest current signals: external survival validation, the CD4 T-helper transcriptional program, a healthy-baseline gradient, and the Dara-clean signaling landscape."
      />

      <FigureLightboxGrid figures={imsCurrentResearchPage.figureGallery} dialogLabel="Current research figures" />
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="Interpretation"
        title="Biological and translational implications"
        body="The surviving signal set points away from the original NK/CD8 headline and toward myeloid expansion, erythroid hazard, mature B-cell protection, and early CD4 T-helper rewiring as the more defensible biology."
      />

      <div class="impact-grid">
        {imsCurrentResearchPage.impactPoints.map((item) => (
          <article class="resume-panel impact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
