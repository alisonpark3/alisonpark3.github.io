---
import MainLayout from "../layouts/MainLayout.astro";
import PublicationCard from "../components/PublicationCard.astro";
import { publications, siteMeta } from "../data/site";

const filters = ["All", "Journal article", "ASH", "IMS", "Awarded", "Single-Cell", "Multi-Omics", "Drug Discovery"];
---

<MainLayout title={`${siteMeta.title} | Publications`} description="Publications and conference abstracts for Alison Seongjee Park.">
  <section class="subpage-hero">
    <div class="content-grid narrow-grid">
      <p class="hero-kicker">Research record</p>
      <h1>Publications</h1>
      <p class="hero-body">
        A clean archive of abstracts, poster records, and the published SETD8 paper, with official links and authorship order on each entry.
      </p>
      <div class="subpage-meta">
        <span class="pill">Official links on every entry</span>
        <span class="pill">Authorship order</span>
        <span class="pill">Poster PDFs where available</span>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <div class="filter-bar" data-filter-root>
        {filters.map((filter, index) => (
          <button class:list={["filter-chip", index === 0 && "is-active"]} type="button" data-filter={filter}>
            {filter}
          </button>
        ))}
      </div>

      <div class="card-grid" data-publication-grid>
        {publications.map((publication) => <PublicationCard publication={publication} />)}
      </div>
    </div>
  </section>

  <script>
    const root = document.querySelector("[data-filter-root]");
    const cards = Array.from(document.querySelectorAll("[data-publication-grid] .publication-card"));

    if (root && cards.length) {
      root.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;

        const filter = target.dataset.filter;
        if (!filter) return;

        root.querySelectorAll(".filter-chip").forEach((chip) => chip.classList.remove("is-active"));
        target.classList.add("is-active");

        cards.forEach((card) => {
          const tags = (card.getAttribute("data-tags") || "").split("|").filter(Boolean);
          const show = filter === "All" || tags.includes(filter);
          card.toggleAttribute("hidden", !show);
        });
      });
    }
  </script>
</MainLayout>
