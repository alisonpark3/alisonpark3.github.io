---
import MainLayout from "../layouts/MainLayout.astro";
import PublicationCard from "../components/PublicationCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { publications, siteMeta } from "../data/site";

const filters = ["All", "Journal article", "ASH", "IMS", "Awarded", "Single-Cell", "Multi-Omics", "Drug Discovery"];
const evidenceGallery = [
  {
    title: "2025 CLML / IMS abstract",
    note: "Abstract-page excerpt used as source evidence for the multi-omics subtype story.",
    src: "/images/papers/out_2025_clml_multiomic_snf/abstract-excerpt.png",
    alt: "Excerpt from the 2025 CLML / IMS abstract page."
  },
  {
    title: "2024 ASH poster: single-cell high-risk NDMM",
    note: "Poster PDF for the antigen-presenting cell and IFN-stimulated CD4 depletion work.",
    src: "/images/papers/out_2024_blood_single_cell_apc/abstract-excerpt.png",
    alt: "Excerpt from the 2024 Blood abstract on single-cell APC and IFN-stimulated CD4 depletion.",
    href: "/files/posters/ASH_2024_POSTER_HRSR_MMRF_FINAL.pdf",
    linkLabel: "Open poster PDF"
  },
  {
    title: "2024 ASH poster: immune profiling / multi-omics PSN",
    note: "Poster PDF for the immune-profiling study of multiple-myeloma subtypes defined by multi-omics network analysis.",
    src: "/images/papers/out_2024_blood_immune_profiling/abstract-excerpt.png",
    alt: "Excerpt from the 2024 Blood abstract on immune profiling and multi-omics network analysis.",
    href: "/files/posters/ASH_2024_POSTER_immunePSN_MMRF.pdf",
    linkLabel: "Open poster PDF"
  },
  {
    title: "2025 Blood shared-immune abstract",
    note: "Abstract-page excerpt from the shared immune-features study across human subtypes and murine models.",
    src: "/images/papers/out_2025_blood_shared_immune_features/abstract-excerpt.png",
    alt: "Excerpt from the 2025 Blood abstract on shared immune features."
  },
  {
    title: "2026 JMC SETD8 paper",
    note: "Real figure crop from the published paper, used where the source includes full figure-level evidence.",
    src: "/images/papers/out_2026_jmc_setd8_inhibitor/figure-invivo.png",
    alt: "Figure excerpt from the 2026 Journal of Medicinal Chemistry SETD8 paper."
  }
];
---

<MainLayout title={`${siteMeta.title} | Publications`} description="Publications and conference abstracts for Alison Seongjee Park.">
  <section class="subpage-hero">
    <div class="content-grid narrow-grid">
      <p class="hero-kicker">Research record</p>
      <h1>Publications and conference abstracts</h1>
      <p class="hero-body">
        This page collects my multiple myeloma work, including subtype modeling, single-cell immune profiling, and SETD8 inhibitor research. I&apos;ve linked
        the official records and posters where they are available.
      </p>
      <div class="subpage-meta">
        <span class="pill">1 journal article</span>
        <span class="pill">7 conference abstracts</span>
        <span class="pill">2 award-marked ASH abstracts</span>
        <span class="pill">Official links on every card</span>
      </div>
    </div>
  </section>

  <section class="section-shell accent-shell">
    <div class="content-grid">
      <SectionHeading
        eyebrow="Selected materials"
        title="Posters and figure excerpts"
      />
      <div class="evidence-grid">
        {evidenceGallery.map((item) => (
          <article class="evidence-card">
            <figure class="story-evidence-figure">
              <img src={item.src} alt={item.alt} loading="lazy" />
              <figcaption>{item.note}</figcaption>
            </figure>
            <div class="evidence-card-copy">
              <p class="meta-kicker">{item.title}</p>
              {item.href && (
                <div class="card-links">
                  <a href={item.href} target="_blank" rel="noreferrer">{item.linkLabel || "Open source"}</a>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
      <div class="contact-strip">
        <a href={siteMeta.downloads.resumePdf} download>Download Resume (PDF)</a>
        <a href={siteMeta.downloads.cvPdf} download>Full CV (PDF)</a>
        <a href={`mailto:${siteMeta.email}`}>Email Alison</a>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-grid">
      <div class="filter-bar" data-filter-root>
        {filters.map((filter, index) => (
          <button class:list={["filter-chip", index === 0 && "is-active"]} type="button" data-filter={filter}>
            {filter}
          </button>
        ))}
      </div>

      <div class="card-grid" data-publication-grid>
        {publications.map((publication) => <PublicationCard publication={publication} />)}
      </div>
    </div>
  </section>

  <script>
    const root = document.querySelector("[data-filter-root]");
    const cards = Array.from(document.querySelectorAll("[data-publication-grid] .publication-card"));

    if (root && cards.length) {
      root.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;

        const filter = target.dataset.filter;
        if (!filter) return;

        root.querySelectorAll(".filter-chip").forEach((chip) => chip.classList.remove("is-active"));
        target.classList.add("is-active");

        cards.forEach((card) => {
          const tags = (card.getAttribute("data-tags") || "").split("|").filter(Boolean);
          const show = filter === "All" || tags.includes(filter);
          card.toggleAttribute("hidden", !show);
        });
      });
    }
  </script>
</MainLayout>
